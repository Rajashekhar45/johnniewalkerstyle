<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Design Tokens %}
    {% render 'css-variables' %}  

    {% # Performance Optimization %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

    {% # Load Antonio and Montserrat %}
    <link href="https://fonts.googleapis.com/css2?family=Antonio:wght@700&family=Montserrat:wght@400;500;700&display=swap" rel="stylesheet">
    
    {% # Load Font Awesome %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
      /* Global Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #FDF9F1; /* Soft cream color matching the image */
        box-shadow: inset 1px 0 0 rgba(0, 0, 0, 0.05); /* Subtle inner line */
      }
      ::-webkit-scrollbar-thumb {
        background: #F8B400; 
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #e3a60f; 
      }
      body::-webkit-scrollbar {
        display: none; /* Prevents double scrolling issue */
      }

      /* Vertical Sidebar - Original JW Graphic Refinement */
      .jw-vertical-sidebar {
        position: fixed;
        top: 50%;
        right: 0; /* Align to the absolute right edge */
        transform: translateY(-50%);
        z-index: 1002;
        pointer-events: none;
        display: flex;
        justify-content: center;
        width: 60px; /* Width to contain the graphic */
      }
      .jw-vertical-sidebar img {
        width: 100%;
        height: auto;
        max-width: 45px;
        pointer-events: auto;
        animation: slideInSidebar 1.2s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
        opacity: 0;
      }

      @keyframes slideInSidebar {
        from { opacity: 0; transform: translateX(20px); }
        to { opacity: 1; transform: translateX(0); }
      }

      /* High-Fidelity Floating Scroll-to-Top Button */
      #scrollUp {
        position: fixed;
        left: 20px;
        bottom: 60px;
        width: 50px;
        height: 50px;
        background-color: #ffbc01;
        color: #fff;
        text-align: center;
        border-radius: 50px;
        z-index: 9811 !important;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        text-decoration: none;
      }

      #scrollUp.is-visible {
        opacity: 1;
        visibility: visible;
      }

      #scrollUp:hover {
        background-color: #e6a901;
      }

      #scrollUp i {
        animation: jw-chevron-up 2s infinite;
        display: inline-block;
        line-height: 50px;
      }

      @keyframes jw-chevron-up {
        0% { transform: translateY(10px); opacity: 0; }
        30% { transform: translateY(0); opacity: 1; }
        100% { transform: translateY(-15px); opacity: 0; }
      }

      @media (max-width: 1024px) {
        .jw-vertical-sidebar { right: 15px; gap: 15px; }
        .sidebar-icon { width: 30px; }
        .vertical-text { font-size: 11px; }
      }

      
    </style>

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {% render 'meta-tags' %}
    {{ content_for_header }}
  </head>

  <body>
 

    <!-- Global High-Fidelity Scroll-to-Top -->
    <a id="scrollUp" href="javascript:void(0)" aria-label="Scroll to Top">
      <i class="fa fa-angle-double-up"></i>
    </a>

    {% sections 'header-group' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1" style="margin-top: 90px;">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% # Final Interaction Layer %}
    <script>
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

      // Global Scroll to Top Logic
      const scrollBtn = document.getElementById('scrollUp');
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          scrollBtn.classList.add('is-visible');
        } else {
          scrollBtn.classList.remove('is-visible');
        }
      });

      scrollBtn.addEventListener('click', () => {
        const duration = 1200;
        const start = window.pageYOffset;
        const startTime = performance.now();

        function scroll() {
          const now = performance.now();
          const time = Math.min(1, (now - startTime) / duration);
          const easedTime = time * time; // Ease-In
          window.scroll(0, Math.ceil((1 - easedTime) * start));
          if (window.pageYOffset > 0) requestAnimationFrame(scroll);
        }
        scroll();
      });
    </script>
  </body>
</html>
