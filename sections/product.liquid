<style>
.jw-product {
  background-color: #0a0a0a;
  min-height: 60vh;
  padding: 60px 40px;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: start;
}

@media (max-width: 768px) {
  .jw-product {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 40px 20px;
  }
}

.jw-product__gallery {
  display: grid;
  gap: 12px;
}

.jw-product__image {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  border: 1px solid #2a2a2a;
}

.jw-product__info {
  padding: 20px 0;
}

.jw-product__title {
  color: #ffffff;
  font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 16px;
  line-height: 1.3;
}

.jw-product__price {
  color: #c9a84c;
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 24px;
}

.jw-product__description {
  color: #999999;
  font-size: 14px;
  line-height: 1.8;
  letter-spacing: 0.03em;
  margin-bottom: 32px;
}

.jw-product__variant-select {
  width: 100%;
  background: #111111;
  border: 1px solid #2a2a2a;
  color: #ffffff;
  padding: 12px 16px;
  font-size: 13px;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
  appearance: none;
  cursor: pointer;
}

.jw-product__quantity {
  width: 80px;
  background: #111111;
  border: 1px solid #2a2a2a;
  color: #ffffff;
  padding: 12px 16px;
  font-size: 13px;
  text-align: center;
  margin-bottom: 24px;
}

.jw-product__add-btn {
  display: block;
  width: 100%;
  padding: 14px;
  background: transparent;
  border: 1px solid #c9a84c;
  color: #c9a84c;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-bottom: 12px;
}

.jw-product__add-btn:hover {
  background-color: #c9a84c;
  color: #0a0a0a;
}
</style>

<div class="jw-product">
  <div class="jw-product__gallery">
    {% for image in product.images %}
      <img
        class="jw-product__image"
        src="{{ image | image_url: width: 800 }}"
        alt="{{ image.alt | default: product.title | escape }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
      >
    {% endfor %}
  </div>

  <div class="jw-product__info">
    <h1 class="jw-product__title">{{ product.title }}</h1>
    <p class="jw-product__price">{{ product.price | money }}</p>

    {% if product.description != blank %}
      <div class="jw-product__description">{{ product.description }}</div>
    {% endif %}

    {% form 'product', product %}
      {% assign current_variant = product.selected_or_first_available_variant %}

      {% if product.variants.size > 1 %}
        <select name="id" class="jw-product__variant-select">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}
                selected="selected"
              {% endif %}
            >
              {{ variant.title }} — {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>
      {% else %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {% endif %}

      <input
        type="number"
        name="quantity"
        min="1"
        value="1"
        class="jw-product__quantity"
      >

      {% if current_variant.available %}
        <button type="submit" class="jw-product__add-btn">Add to Cart</button>
      {% else %}
        <button type="button" class="jw-product__add-btn" style="opacity:0.5;cursor:not-allowed;" disabled>Sold Out</button>
      {% endif %}

      {{ form | payment_button }}
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
