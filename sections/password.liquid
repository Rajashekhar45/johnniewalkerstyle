<style>
.jw-password {
  background-color: #0a0a0a;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 60px 40px;
}

.jw-password__title {
  color: #ffffff;
  font-size: clamp(1.5rem, 4vw, 3rem);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.jw-password__message {
  color: #999999;
  font-size: 14px;
  letter-spacing: 0.05em;
  margin-bottom: 40px;
  max-width: 500px;
}

.jw-password__form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  width: 100%;
  max-width: 400px;
}

.jw-password__label {
  color: #999999;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.jw-password__input {
  width: 100%;
  background: #111111;
  border: 1px solid #2a2a2a;
  color: #ffffff;
  padding: 14px 20px;
  font-size: 14px;
  text-align: center;
  letter-spacing: 0.1em;
  box-sizing: border-box;
}

.jw-password__submit {
  width: 100%;
  background: transparent;
  border: 1px solid #c9a84c;
  color: #c9a84c;
  padding: 14px;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
}

.jw-password__submit:hover {
  background-color: #c9a84c;
  color: #0a0a0a;
}

.jw-password__errors {
  color: #ff4444;
  font-size: 13px;
  margin-bottom: 16px;
}
</style>

<div class="jw-password">
  <h1 class="jw-password__title">{{ 'password.title' | t }}</h1>

  {% if shop.password_message %}
    <p class="jw-password__message">{{ shop.password_message }}</p>
  {% endif %}

  {% form 'storefront_password' %}
    {% if form.errors %}
      <div class="jw-password__errors">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="jw-password__form">
      <label for="password-input" class="jw-password__label">
        {{ 'password.password' | t }}
      </label>

      <input
        type="password"
        name="password"
        id="password-input"
        class="jw-password__input"
        placeholder="Enter password"
      >

      <button type="submit" class="jw-password__submit">
        {{ 'password.enter' | t }}
      </button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
