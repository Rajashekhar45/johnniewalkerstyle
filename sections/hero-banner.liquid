<section class="hero-banner hero--{{ section.id }} {% if section.settings.full_height %}hero--full-height{% endif %}">
  {% # Background Media %}
  <div class="hero-banner__media">
    {% if section.settings.video_url != blank %}
      <video
        src="{{ section.settings.video_url }}"
        autoplay
        loop
        muted
        playsinline
        class="hero-media"
      ></video>
    {% elsif section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 3840 | image_tag: class: 'hero-media', loading: 'eager', widths: '750, 1100, 1500, 1780, 2000, 3000, 3840' }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'hero-media placeholder-svg' }}
    {% endif %}
  </div>

  <div class="hero-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>

  {% # Content %}
  <div class="hero-banner__content container-boxed">
    <div class="hero-banner__text-wrap reveal">
      {% if section.settings.subheading != blank %}
        <p class="hero-banner__subheading delay-1">{{ section.settings.subheading }}</p>
      {% endif %}
      
      <h1 class="hero-banner__heading delay-2">
        {{ section.settings.heading | newline_to_br }}
      </h1>

      {% if section.settings.button_label != blank %}
        <div class="hero-banner__actions delay-3">
          <a href="{{ section.settings.button_link }}" class="jw-btn jw-btn--gold">
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="jw-line-overlay"></div>
</section>

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    min-height: 600px;
    height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #000;
  }

  .hero--full-height {
    height: 100vh;
  }

  .hero-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, rgba(10, 10, 10, 0.8));
    z-index: 1;
  }

  .hero-banner__content {
    position: relative;
    z-index: 10;
    width: 100%;
    text-align: center;
  }

  .hero-banner__subheading {
    font-size: 14px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--jw-gold);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .hero-banner__heading {
    font-size: clamp(2.5rem, 8vw, 6rem);
    line-height: 1.1;
    color: var(--jw-white);
    margin-bottom: 40px;
    font-weight: 700;
  }

  .jw-btn {
    display: inline-block;
    padding: 18px 50px;
    font-size: 13px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 700;
    transition: all 0.4s ease;
    border: 1px solid var(--jw-gold);
  }

  .jw-btn--gold {
    background: transparent;
    color: var(--jw-gold);
  }

  .jw-btn--gold:hover {
    background: var(--jw-gold);
    color: var(--jw-black);
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .hero-banner { height: 70vh; min-height: 500px; }
    .hero-banner__heading { font-size: 3rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const reveals = document.querySelectorAll('.hero-banner .reveal');
    setTimeout(() => {
      reveals.forEach(r => r.classList.add('active'));
    }, 100);
  });
</script>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background Video URL (optional)"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full Window Height",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "default": 30,
      "label": "Overlay Opacity"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "PREMIUM COLLECTION"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "KEEP WALKING"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Styles"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
