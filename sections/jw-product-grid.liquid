<section class="jw-product-grid-refined reveal">
  <div class="container-boxed">
    <div class="section-title-wrap">
      {% if section.settings.heading != blank %}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="jw-products-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection != blank %}
        {% for product in collection.products limit: section.settings.products_count %}
          <div class="jw-product-card">
              <div class="product-media-container">
                <a href="{{ product.url }}" class="product-media-link">
                  <!-- Badges -->
                  <div class="product-badges">
                    {% if product.available == false %}
                      <span class="badge badge--sold-out">SOLD OUT</span>
                    {% elsif product.tags contains 'new' %}
                      <span class="badge badge--new">NEW</span>
                    {% endif %}
                  </div>

                  <!-- Primary Image -->
                  <img src="{{ product.featured_media | image_url: width: 800 }}" 
                       alt="{{ product.title | escape }}"
                       class="product-main-img primary"
                       loading="lazy"
                       width="800"
                       height="{{ 800 | divided_by: product.featured_media.aspect_ratio | round }}">

                  <!-- Secondary Image (Cross-fade) -->
                  {% if product.media.size > 1 %}
                    <img src="{{ product.media[1] | image_url: width: 800 }}" 
                         alt="{{ product.title | escape }}"
                         class="product-main-img secondary"
                         loading="lazy"
                         width="800"
                         height="{{ 800 | divided_by: product.media[1].aspect_ratio | round }}">
                  {% endif %}
                </a>
                
                <!-- High-Fidelity Add to Cart Hover Button -->
                {% if product.available %}
                  <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="quick-add-form">
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <button type="submit" class="btn-hover-atc">
                      <i class="fas fa-shopping-cart"></i>
                      <span>Add To Cart</span>
                    </button>
                  </form>
                {% endif %}
              </div>

            <div class="product-info-refined">
              <h3 class="product-title-refined">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <p class="product-price-refined"><span class="currency">฿</span>{{ product.price | money_without_currency }}</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  .jw-product-grid-refined {
    padding: var(--section-spacing) 0;
    background-color: #FFFFFF;
  }

  .section-title-wrap {
    margin-bottom: 70px;
    text-align: center;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: 0.05em;
    color: #000000;
  }

  .jw-products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  /* Refined Product Card */
  .jw-product-card {
    background-color: #FFFFFF;
    transition: var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .product-media-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1.25;
    background-color: #F9F9F9;
    overflow: hidden;
  }

  .product-media-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .product-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.6s ease, opacity 0.6s ease;
  }

  .product-main-img.secondary {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    z-index: 2;
  }

  .jw-product-card:hover .product-main-img.primary {
    opacity: 0;
  }

  .jw-product-card:hover .product-main-img.secondary {
    opacity: 1;
  }

  .jw-product-card:hover .product-main-img.primary:not(.secondary) {
    opacity: 1;
  }

  /* Badges Styling */
  .product-badges {
    position: absolute;
    top: 15px;
    left: 15px;
    z-index: 10;
    pointer-events: none;
  }

  .badge {
    display: inline-block;
    padding: 6px 12px;
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 2px;
  }

  .badge--sold-out {
    background-color: #000000;
    color: #FFFFFF;
  }

  .badge--new {
    background-color: var(--jw-gold);
    color: #000000;
  }

  /* High-Fidelity Add to Cart Full Width Bar */
  .btn-hover-atc {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 15px 10px;
    background-color: #F8B400; /* Orange Hover on Image */
    color: #FFFFFF;
    border: none;
    border-radius: 0;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(100%);
    transition: all 0.35s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 10;
  }

  .btn-hover-atc i {
    font-size: 14px;
  }

  .jw-product-card:hover .btn-hover-atc {
    opacity: 1;
    transform: translateY(0);
  }

  .btn-hover-atc:hover {
    background-color: #000000 !important; /* Final Black Hover */
  }

  /* Info Polish */
  .product-info-refined {
    padding: 25px 0;
    text-align: left; /* Aligned left for premium look */
  }

  .product-title-refined {
    font-size: 13px;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
  }

  .product-price-refined {
    font-size: 16px;
    font-weight: 800;
    color: #000000;
    letter-spacing: 0.02em;
  }

  .product-price-refined .currency {
    margin-right: 2px;
  }

  @media (max-width: 1024px) {
    .jw-products-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .product-micro-actions { opacity: 1; transform: none; } /* Always visible on mobile for UX */
  }

  @media (max-width: 768px) {
    .jw-products-grid { grid-template-columns: 1fr; }
    .section-heading { font-size: 2.5rem; }
  }
</style>

{% schema %}
{
  "name": "JW Product Grid Refined",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "SELECTED STYLE"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 3,
      "label": "Products to Show"
    }
  ],
  "presets": [
    {
      "name": "JW Product Grid Refined"
    }
  ]
}
{% endschema %}
