<section class="jw-product-grid-refined reveal">
  <div class="container-boxed">
    <div class="section-title-wrap">
      {% if section.settings.heading != blank %}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="jw-products-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection != blank %}
        {% for product in collection.products limit: section.settings.products_count %}
          <div class="jw-product-card">
            <div class="product-media-container">
              <a href="{{ product.url }}" class="product-media-link">
                <img src="{{ product.featured_media | image_url: width: 800 }}" 
                     alt="{{ product.title | escape }}"
                     class="product-main-img"
                     loading="lazy"
                     width="800"
                     height="auto">
              </a>
              
              <div class="product-micro-actions">
                <form method="post" action="{{ routes.cart_add_url }}" class="atc-micro-form">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" class="btn-micro-atc" aria-label="Quick Add to Cart">
                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="3" fill="none"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                  </button>
                </form>
              </div>
            </div>

            <div class="product-info-refined">
              <h3 class="product-title-refined">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <p class="product-price-refined">{{ product.price | money }}</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  .jw-product-grid-refined {
    padding: var(--section-spacing) 0;
    background-color: #FFFFFF;
  }

  .section-title-wrap {
    margin-bottom: 70px;
    text-align: center;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: 0.05em;
    color: #000000;
  }

  .jw-products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  /* Refined Product Card */
  .jw-product-card {
    background-color: #FFFFFF;
    transition: var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .product-media-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1.25;
    background-color: #F9F9F9;
    overflow: hidden;
  }

  .product-media-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .product-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: var(--transition-slow);
  }

  .jw-product-card:hover .product-main-img { transform: scale(1.05); }

  /* Micro-Interaction Button (+) in Corner */
  .product-micro-actions {
    position: absolute;
    bottom: 20px;
    left: 20px;
    opacity: 0;
    transform: translateY(10px);
    transition: var(--transition-base);
    z-index: 5;
  }
  
  .jw-product-card:hover .product-micro-actions { opacity: 1; transform: translateY(0); }

  .btn-micro-atc {
    width: 45px;
    height: 45px;
    background-color: #000000;
    color: #FFFFFF;
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    transition: var(--transition-fast);
  }
  .btn-micro-atc:hover { background-color: var(--jw-gold); color: #000000; transform: scale(1.1); }

  /* Info Polish */
  .product-info-refined {
    padding: 25px 0;
    text-align: left; /* Aligned left for premium look */
  }

  .product-title-refined {
    font-size: 13px;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    font-weight: 700;
    color: #000000;
    text-transform: uppercase;
  }

  .product-price-refined {
    font-size: 15px;
    font-weight: 700;
    color: #000000;
  }

  @media (max-width: 1024px) {
    .jw-products-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .product-micro-actions { opacity: 1; transform: none; } /* Always visible on mobile for UX */
  }

  @media (max-width: 768px) {
    .jw-products-grid { grid-template-columns: 1fr; }
    .section-heading { font-size: 2.5rem; }
  }
</style>

{% schema %}
{
  "name": "JW Product Grid Refined",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "SELECTED STYLE"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 3,
      "label": "Products to Show"
    }
  ],
  "presets": [
    {
      "name": "JW Product Grid Refined"
    }
  ]
}
{% endschema %}
