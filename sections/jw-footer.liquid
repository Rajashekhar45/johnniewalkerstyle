<footer class="jw-footer-high-fidelity reveal">
  <!-- Top Gold Bar Accent -->
  <div class="footer-top-accent"></div>

  <!-- Main Black Body -->
  <div class="footer-mid-black">
    <div class="container-full">
      <div class="footer-hashtags-wrap">
        <h2 class="footer-hashtag-text">#JOHNNIEWALKERSTYLE</h2>
        <div class="footer-shop-btn-wrap">
          <a href="{{ section.settings.shop_btn_link | default: routes.all_products_collection_url }}" class="footer-shop-btn">
            {{ section.settings.shop_btn_label | default: 'SHOP NOW' }}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Triple-Row Gold Bottom Bar -->
  <div class="footer-bottom-gold">
    <div class="container-full footer-bottom-inner">
      
      
      <div class="footer-legal-content">
        <!-- Row 1: Legal Links -->
        <div class="footer-legal-links">
          {% for link in section.settings.legal_menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
            {% unless forloop.last %}<span class="footer-pipe">|</span>{% endunless %}
          {% else %}
            <!-- Matching image defaults -->
            <a href="#">Conditions of Use</a> <span class="footer-pipe">|</span>
            <a href="#">Privacy and Cookie Notice</a> <span class="footer-pipe">|</span>
            <a href="#">UGC Policy</a> <span class="footer-pipe">|</span>
            <a href="#">Accessibility</a> <span class="footer-pipe">|</span>
            <a href="#">Privacy Settings</a> <span class="footer-pipe">|</span>
            <a href="#">Diageo Privacy Centre</a> <span class="footer-pipe">|</span>
            <a href="#">DrinkIQ</a> <span class="footer-pipe">|</span>
            <a href="#">theBar.com</a> <span class="footer-pipe">|</span>
            <a href="#">Responsible Drinking</a>
          {% endfor %}
        </div>

        <!-- Row 2: Copyright -->
        <div class="footer-copyright">
          COPYRIGHT © {{ 'now' | date: "%Y" }} DIAGEO
        </div>

        <!-- Row 3: Age Disclaimer -->
        <div class="footer-age-disclaimer">
          Please do not share with anyone under the legal purchase age for alcohol. Drink responsibly.
        </div>
      </div>

    </div>
  </div>
</footer>

<style>
  .jw-footer-high-fidelity {
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .footer-top-accent {
    padding-top: 15px;
    padding-bottom: 15px;
    background-color: var(--jw-gold);
    width: 100%;
  }

  .footer-mid-black {
    background-color: #000000;
    padding: 100px 0;
    text-align: center;
  }

  .footer-hashtag-text {
    font-family: var(--font-heading);
    font-size: 25px; /* High fidelity size */
    color: #FFFFFF;
    letter-spacing: 3px;
    margin: 0 0 10px 0;
    line-height: 1;
  }

  .footer-shop-btn {
   
    
        margin-top: 10px;
    font-family: "JohnnieWalkerWeb Headline" !important;
    font-size: 20px;
    background-color: transparent;
    color: #FFF;
    border: 5px solid #FFF;
    padding: 15px 32px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
  }

  .footer-bottom-gold {
    background-color: var(--jw-gold);
    color: #000000;
    padding: 15px 0;
  }

  .footer-bottom-inner {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    /*padding-top: 20px;*/
  }

  .footer-legal-content {
    display: flex;
    flex-direction: column;
    align-items: center;
   /* gap: 10px;
    max-width: 1100px;*/
    text-align: center;
  }

  .footer-legal-links {
    font-size: 12px;
    letter-spacing: .9px;
    line-height: 1.6;
  }
  .footer-legal-links a {
       color: #000000;
    text-decoration: none;
    font-size: 14px;
    line-height: 24px;
    font-weight: 400;
   
  }
  .footer-legal-links a:hover {
    color: #2D2926;
  }
  .footer-pipe {
    margin: 0 4px;
    
    opacity: 0.6;
  }

  .footer-copyright {
    color: #000;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: .9px;
    margin-bottom:10px;
  }

  .footer-age-disclaimer {
    font-size: 15px;
    text-align: center;
    letter-spacing: .9px;
    font-family: "Poppins", sans-serif;
  }

  @media (max-width: 768px) {
    .footer-hashtag-text { font-size: 32px; }
    .footer-scroll-top { position: static; margin-bottom: 20px; }
    .footer-bottom-inner { flex-direction: column; }
    .footer-legal-links { font-size: 10px; }
    .footer-pipe { display: none; }
    .footer-legal-links a { display: block; margin-bottom: 5px; }
  }
</style>

{% schema %} 
{
  "name": "JW Footer High-Fidelity",
  "settings": [
    {
      "type": "text",
      "id": "shop_btn_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "shop_btn_link",
      "label": "Button Link"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal Links Menu"
    }
  ],
  "presets": [
    {
      "name": "JW Footer High-Fidelity"
    }
  ]
}
{% endschema %}

{% javascript %}
{% endjavascript %}
