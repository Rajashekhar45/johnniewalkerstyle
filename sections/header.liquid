<header class="jw-header" id="Header">
  <div class="header-main">
    <div class="container-full header-inner">
      <div class="header-left">
        <a href="{{ routes.root_url }}" class="logo-container">
          <img src="https://www.johnniewalkerstyle.com/upload/setting/logo/1681747566.png" alt="Johnnie Walker Style" loading="lazy" width="220" height="48">
        </a>
        <nav class="jw-nav desktop-only">
          {% for link in section.settings.menu.links %}
            <a href="{{ link.url }}" class="jw-nav-link">{{ link.title }}</a>
          {% endfor %}
        </nav>
      </div>

      <div class="header-right">
        <div class="header-icons">
          <a href="{{ routes.search_url }}" class="header-icon-btn search-trigger" aria-label="Search">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="1.5" fill="none" class="icon-search-fidelity">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </a>
          <div class="header-cart-wrapper">
            <a href="{{ routes.cart_url }}" class="header-icon-btn cart-trigger" id="CartTrigger" aria-label="Cart">
              <i class="fas fa-shopping-bag" style="font-size: 20px;"></i>
              <span class="cart-badge-fidelity" id="CartBadge">{{ cart.item_count }}</span>
            </a>

            <!-- Cart Dropdown -->
            <div class="cart-dropdown" id="CartDropdown">
              {% if cart.item_count > 0 %}
                <div class="cart-dropdown-items">
                  {% for item in cart.items %}
                    <div class="cart-dropdown-item">
                      <div class="cart-dropdown-item-image">
                        <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title | escape }}" loading="lazy" width="80" height="80">
                      </div>
                      <div class="cart-dropdown-item-details">
                        <h4 class="cart-item-title">{{ item.product.title }}</h4>
                        {% unless item.product.has_only_default_variant %}
                          <p class="cart-item-variant">[{{ item.variant.title }}]</p>
                        {% endunless %}
                        <p class="cart-item-qty"><strong>Qty: {{ item.quantity }}</strong></p>
                        <p class="cart-item-price">{{ item.final_line_price | money }}</p>
                      </div>
                      <a href="{{ item.url_to_remove }}" class="cart-item-remove" aria-label="Remove item">
                        <i class="fas fa-times"></i>
                      </a>
                    </div>
                  {% endfor %}
                </div>
                <div class="cart-dropdown-footer">
                  <div class="cart-dropdown-total">
                    <strong>Total :</strong>
                    <strong>{{ cart.total_price | money }}</strong>
                  </div>
                  <div class="cart-dropdown-actions">
                    <a href="{{ routes.cart_url }}" class="cart-dropdown-btn">VIEW CART</a>
                    <form action="{{ routes.cart_url }}" method="post" id="cart-dropdown-form">
                      <button type="submit" name="checkout" class="cart-dropdown-btn">CHECKOUT</button>
                    </form>
                  </div>
                </div>
              {% else %}
                <div class="cart-dropdown-empty">
                  <p>Your cart is currently empty.</p>
                  <a href="{{ routes.all_products_collection_url }}" class="cart-dropdown-btn" style="margin-top:20px;">SHOP NOW</a>
                </div>
              {% endif %}
            </div>
          </div>
          <button class="menu-toggle mobile-only" id="MenuToggle" aria-label="Toggle Menu">
            <span class="bar-1"></span>
            <span class="bar-2"></span>
          </button>
        </div>
      </div>
    </div>
  </div>

  {% if section.settings.show_announcement %}
    <div class="header-announcement-bar">
      <div class="container-full">
        <p class="announcement-text">{{ section.settings.announcement_text }}</p>
      </div>
    </div>
  {% endif %}

  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu-overlay" id="MobileMenu">
    <div class="mobile-menu-inner">
      <nav class="mobile-nav">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}" class="mobile-nav-link text-reveal">{{ link.title }}</a>
        {% endfor %}
      </nav>
      <div class="mobile-menu-footer">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
      </div>
    </div>
  </div>
</header>

<style>
  .jw-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 2000;
  }

  .header-main {
    background-color: #000000;
    color: #FFFFFF;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 90px; 
    padding: 0 40px;
  }

  .header-left { 
    display: flex; 
    align-items: center; 
    gap: 60px; 
  }
  
  .header-right { 
    display: flex; 
    align-items: center; 
    justify-content: flex-end; 
  }

  /* Image Logo */
  .logo-container {
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }
  .logo-container:hover {
    opacity: 0.8;
  }
  .logo-container img {
    height: 48px; /* Maintain standard header height */
    width: auto;
    display: block;
  }

  /* Desktop Navigation */
  .jw-nav {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .jw-nav-link {
    font-family: 'Antonio', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #FFFFFF;
    transition: color 0.2s ease;
  }
  .jw-nav-link:hover {
    color: var(--jw-gold);
  }

  /* Icons */
  .header-icons { 
    display: flex; 
    align-items: center; 
    gap: 25px; 
  }
  .header-icon-btn {
    color: #FFFFFF;
    display: flex;
    align-items: center;
    position: relative;
    transition: var(--transition-fast);
  }
  .header-icon-btn:hover { 
    color: var(--jw-gold); 
    transform: scale(1.1);
  }

  .cart-badge-fidelity {
    font-family: 'Antonio', sans-serif;
    font-size: 11px;
    font-weight: 700;
    position: absolute;
    top: -2px;
    right: -4px;
    background: #FFFFFF;
    color: #000000;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Cart Dropdown Styles */
  .header-cart-wrapper {
    position: relative;
  }

  .cart-dropdown {
    position: absolute;
    top: calc(100% + 25px);
    right: -20px;
    width: 380px;
    background: #FFFFFF;
    color: #000000;
    box-shadow: 0 5px 20px rgba(0,0,0,0.15);
    padding: 20px;
    border-radius: 4px;
    visibility: hidden;
    opacity: 0;
    transform: translateY(10px);
    transition: var(--transition-base);
    z-index: 3000;
    border: 1px solid #EEEEEE;
  }
  .cart-dropdown.is-active {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
  }

  .cart-dropdown-items {
    max-height: 350px;
    overflow-y: auto;
    margin-bottom: 15px;
    padding-right: 5px;
  }
  /* Custom scrollbar for items */
  .cart-dropdown-items::-webkit-scrollbar { width: 4px; }
  .cart-dropdown-items::-webkit-scrollbar-thumb { background: #E8AC0D; border-radius: 2px; }

  .cart-dropdown-item {
    display: flex;
    gap: 15px;
    position: relative;
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid #EEEEEE;
  }

  .cart-dropdown-item-image {
    width: 90px;
    flex-shrink: 0;
  }
  .cart-dropdown-item-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .cart-dropdown-item-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
    color: #000000;
  }

  .cart-item-title {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    text-transform: none;
    letter-spacing: normal;
  }

  .cart-item-variant {
    font-size: 13px;
    color: #555555;
    margin: 0;
  }

  .cart-item-qty, .cart-item-price {
    font-size: 14px;
    margin: 0;
  }

  .cart-item-remove {
    position: absolute;
    top: 0;
    right: 0;
    background: #FFC107;
    color: #FFFFFF;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .cart-item-remove:hover {
    background: #000000;
  }

  .cart-dropdown-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0 20px;
    font-size: 16px;
    font-weight: 700;
    color: #000000;
  }

  .cart-dropdown-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart-dropdown-btn {
    display: block;
    width: 100%;
    padding: 14px;
    text-align: center;
    border: 1px solid #000000;
    background: #FFFFFF;
    color: #000000;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: var(--transition-fast);
    cursor: pointer;
  }
  .cart-dropdown-btn:hover {
    background: #000000;
    color: #FFFFFF;
  }

  .cart-dropdown-empty {
    text-align: center;
    padding: 30px 0;
    color: #000000;
  }

  @media (max-width: 1024px) {
    .cart-dropdown {
      position: fixed;
      top: 70px; /* Header height */
      right: 0;
      width: 100%;
      height: calc(100vh - 70px);
      border-radius: 0;
      box-shadow: none;
    }
  }

  /* Mobile Styles */
  .mobile-only { display: none; }

  .menu-toggle {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    z-index: 3000;
  }
  .menu-toggle span {
    display: block;
    width: 28px;
    height: 2px;
    background: #FFFFFF;
    transition: var(--transition-fast);
  }

  /* Mobile Menu Overlay */
  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: #000000;
    z-index: 2500;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.77, 0, 0.175, 1);
  }
  .mobile-menu-overlay.is-active {
    transform: translateX(0);
  }

  .mobile-menu-inner {
    text-align: center;
    width: 100%;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .mobile-nav-link {
    font-family: 'Antonio', sans-serif;
    font-size: 42px;
    font-weight: 700;
    text-transform: uppercase;
    color: #FFFFFF;
    letter-spacing: 0.05em;
  }
  .mobile-nav-link:hover {
    color: var(--jw-gold);
  }

  .mobile-menu-footer {
    position: absolute;
    bottom: 50px;
    left: 0;
    width: 100%;
    color: rgba(255,255,255,0.5);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  /* Hamburger Animation */
  .menu-toggle.is-active .bar-1 {
    transform: translateY(4px) rotate(45deg);
  }
  .menu-toggle.is-active .bar-2 {
    transform: translateY(-4px) rotate(-45deg);
  }

  @media (max-width: 1024px) {
    .header-inner { 
      height: 70px; 
      padding: 0 20px;
    }
    .desktop-only { display: none; }
    .mobile-only { display: flex; }
    .logo-container img { height: 35px; }
  }

  /* Announcement Bar */
  .header-announcement-bar {
    background-color: #F8F4E1; 
    color: #000000;
    padding: 10px 0;
    text-align: center;
  }
  .announcement-text {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuToggle = document.getElementById('MenuToggle');
    const mobileMenu = document.getElementById('MobileMenu');
    const cartTrigger = document.getElementById('CartTrigger');
    const cartDropdown = document.getElementById('CartDropdown');
    const body = document.body;

    // Toggle Cart Dropdown
    if (cartTrigger && cartDropdown) {
      cartTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        cartDropdown.classList.toggle('is-active');
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!cartTrigger.contains(e.target) && !cartDropdown.contains(e.target)) {
          cartDropdown.classList.remove('is-active');
        }
      });
    }

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', () => {
        const isActive = menuToggle.classList.toggle('is-active');
        mobileMenu.classList.toggle('is-active');
        
        if (isActive) {
          body.style.overflow = 'hidden';
        } else {
          body.style.overflow = '';
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "JW Header High-Fidelity",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "JOHNNIE WALKER STYLE"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": false
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "SPECIAL PRICE !!! KEEP WALKING COLLECTION"
    }
  ],
  "presets": [
    {
      "name": "JW Header High-Fidelity"
    }
  ]
}
{% endschema %}
